---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className } = Astro.props;
---

<div class:list={["section-title", className]} data-reveal="content">
  <h2 class="section-title__heading">{title}</h2>
  {subtitle && <p class="section-title__subtitle">{subtitle}</p>}
</div>

<style>
  .section-title {
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .section-title__heading {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 28px;
    color: var(--color-text-primary);
    line-height: 1.35;
  }

  .section-title__subtitle {
    margin: 0.65rem 0 0;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  @media (min-width: 768px) {
    .section-title {
      margin-bottom: 3rem;
    }
  }
</style>
