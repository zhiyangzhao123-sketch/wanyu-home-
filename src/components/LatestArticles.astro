---
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import SectionTitle from "./SectionTitle.astro";
import { formatDate, getReadingMinutes } from "../utils/content";
import cover01 from "../assets/covers/cover-01.jpg";
import cover02 from "../assets/covers/cover-02.jpg";
import cover03 from "../assets/covers/cover-03.jpg";

const coverMap: Record<string, ImageMetadata> = {
  "cover-01": cover01,
  "cover-02": cover02,
  "cover-03": cover03,
};

const articles = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section id="latest-articles" class="articles-section section-padding" data-reveal="content">
  <div class="container-content">
    <SectionTitle title="最新文章" subtitle="认真写下来的一些事" />

    <div class="articles-list">
      {
        articles.map((article, index) => {
          const coverKey = article.data.cover ?? "";
          const cover = coverMap[coverKey];
          const readingMinutes = getReadingMinutes(article.body ?? "");
          const reversed = index % 2 === 1;

          return (
            <article
              class:list={["article-row", { "article-row--reverse": reversed }]}
              data-reveal="content"
              data-reveal-delay="60"
            >
              {cover && (
                <a
                  href={`/blog/${article.id}`}
                  class="article-row__media"
                  data-reveal="image"
                  aria-label={`阅读：${article.data.title}`}
                >
                  <img
                    src={cover.src}
                    alt=""
                    width={cover.width}
                    height={cover.height}
                    loading="lazy"
                    decoding="async"
                  />
                </a>
              )}

              <div class="article-row__body" data-reveal="content" data-reveal-delay="120">
                <span class="article-row__tag">{article.data.category}</span>
                <h3 class="article-row__title">
                  <a href={`/blog/${article.id}`}>{article.data.title}</a>
                </h3>
                <p class="article-row__desc">{article.data.description}</p>
                <div class="article-row__meta">
                  <time datetime={article.data.pubDate.toISOString()}>
                    {formatDate(article.data.pubDate)}
                  </time>
                  <span class="article-row__dot" aria-hidden="true">·</span>
                  <span>约 {readingMinutes} 分钟</span>
                </div>
                <a href={`/blog/${article.id}`} class="article-row__read">
                  阅读全文 →
                </a>
              </div>
            </article>
          );
        })
      }
    </div>

    <p class="articles-more" data-reveal="content" data-reveal-delay="120">
      <a href="/blog" class="articles-more__link">看看全部文章 →</a>
    </p>
  </div>
</section>

<style>
  .articles-section {
    background-color: var(--color-surface-alt);
  }

  .articles-list {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  @media (min-width: 768px) {
    .articles-list {
      gap: 5rem;
    }
  }

  .article-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .article-row {
      grid-template-columns: 1.22fr 1fr;
      gap: 2.5rem;
    }

    .article-row--reverse {
      direction: rtl;
    }

    .article-row--reverse > * {
      direction: ltr;
    }
  }

  .article-row__media {
    display: block;
    overflow: hidden;
    border-radius: 20px;
    aspect-ratio: 16 / 10;
    box-shadow: var(--shadow-card);
  }

  .article-row__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .article-row:hover .article-row__media img {
    transform: scale(1.03);
  }

  .article-row__body {
    padding-inline: 0.15rem;
  }

  .article-row__tag {
    display: inline-block;
    padding: 0.28rem 0.75rem;
    border-radius: 999px;
    background-color: rgb(231 185 138 / 22%);
    color: var(--color-text-primary);
    font-size: 0.78rem;
    line-height: 1.4;
  }

  .article-row__title {
    margin: 0.85rem 0 0;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.5vw, 1.625rem);
    line-height: 1.45;
  }

  .article-row__title a {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .article-row:hover .article-row__title a {
    color: var(--color-brand);
  }

  .article-row__desc {
    margin: 0.75rem 0 0;
    color: var(--color-text-secondary);
    font-size: 0.98rem;
    line-height: 1.75;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .article-row__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    margin-top: 1rem;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
  }

  .article-row__dot {
    opacity: 0.6;
  }

  .article-row__read {
    display: inline-block;
    margin-top: 1.1rem;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .article-row__read:hover {
    color: var(--color-brand);
  }

  .articles-more {
    margin: 3rem 0 0;
    text-align: center;
  }

  .articles-more__link {
    color: var(--color-text-secondary);
    font-size: 0.92rem;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .articles-more__link:hover {
    color: var(--color-brand);
  }
</style>
