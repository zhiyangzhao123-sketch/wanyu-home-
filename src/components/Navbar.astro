---
import { tracks } from "../data/music-tracks";

const navLinks = [
  { href: "/", label: "首页" },
  { href: "/blog", label: "文章" },
  { href: "/thoughts", label: "碎碎念" },
  { href: "/gallery", label: "相册" },
  { href: "/guestbook", label: "留言板" },
  { href: "/about", label: "关于我" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

function isActive(href: string) {
  const normalized = href.replace(/\/$/, "") || "/";
  if (normalized === "/") return currentPath === "/";
  return currentPath === normalized || currentPath.startsWith(`${normalized}/`);
}
---

<header
  id="site-navbar"
  class="site-navbar nav-stage-1"
  data-site-navbar
>
  <nav class="site-navbar__inner container-content" aria-label="主要導覽">
    <div class="site-navbar__brand-group">
      <a href="/" class="site-navbar__brand">
        <svg
          class="site-navbar__logo"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10.5" stroke="currentColor" stroke-width="1.4"></circle>
          <circle cx="9" cy="10.5" r="1" fill="currentColor"></circle>
          <circle cx="15" cy="10.5" r="1" fill="currentColor"></circle>
          <path
            d="M9 14.5c1 1.2 5 1.2 6 0"
            stroke="currentColor"
            stroke-width="1.3"
            stroke-linecap="round"></path>
          <path
            d="M8.5 6.5c.8-.8 2.2-.8 3 0M12.5 6.5c.8-.8 2.2-.8 3 0"
            stroke="currentColor"
            stroke-width="1"
            stroke-linecap="round"></path>
        </svg>
        宛瑜的小窝
      </a>

      <p class="site-navbar__now-playing" data-now-playing hidden>
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path
            d="M9.5 15.8c-1.1 0-2-.85-2-1.9s.9-1.9 2-1.9c.34 0 .66.08.94.23V8.4c0-.32.22-.6.53-.67l4.5-1c.4-.09.78.22.78.63v5.75c0 1.05-.9 1.9-2 1.9s-2-.85-2-1.9.9-1.9 2-1.9c.15 0 .3.02.44.05V9.3l-3.5.78v4.62c0 .05 0 .1-.01.15-.03.99-.9 1.79-1.94 1.79Z"
            fill="currentColor"></path>
        </svg>
        <span class="site-navbar__now-playing-text" data-now-playing-text></span>
      </p>
    </div>

    <ul class="site-navbar__links">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "site-navbar__link",
                { "is-active": isActive(href) },
              ]}
              aria-current={isActive(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="site-navbar__music" data-music-mini>
      <button
        type="button"
        class="site-navbar__music-toggle"
        data-music-mini-toggle
        aria-label="播放音乐"
        aria-pressed="false"
        disabled
      >
        <svg
          class="site-navbar__music-icon site-navbar__music-icon--play"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path d="M7 5.5v13l11-6.5-11-6.5Z" fill="currentColor"></path>
        </svg>
        <svg
          class="site-navbar__music-icon site-navbar__music-icon--pause"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <rect x="6" y="5" width="4" height="14" rx="1" fill="currentColor"></rect>
          <rect x="14" y="5" width="4" height="14" rx="1" fill="currentColor"></rect>
        </svg>
      </button>

      {
        tracks.length > 0 && (
          <button
            type="button"
            class="site-navbar__music-list-toggle"
            data-music-playlist-toggle
            aria-label="播放列表"
            aria-haspopup="listbox"
            aria-expanded="false"
            disabled
          >
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="5" cy="7" r="1.3" fill="currentColor"></circle>
              <circle cx="5" cy="12" r="1.3" fill="currentColor"></circle>
              <circle cx="5" cy="17" r="1.3" fill="currentColor"></circle>
              <path
                d="M9.5 7h9M9.5 12h9M9.5 17h9"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"></path>
            </svg>
          </button>
        )
      }

      {
        tracks.length > 0 && (
          <ul
            class="site-navbar__music-playlist"
            data-music-playlist
            hidden
            role="listbox"
            aria-label="播放列表"
          >
            {tracks.map((track, index) => (
              <li role="presentation">
                <button
                  type="button"
                  class="site-navbar__music-playlist-item"
                  data-music-playlist-item
                  data-track-index={index}
                  role="option"
                  aria-selected="false"
                >
                  <span class="site-navbar__music-playlist-marker" aria-hidden="true">
                    ▶
                  </span>
                  <span class="site-navbar__music-playlist-text">
                    <span class="site-navbar__music-playlist-title">{track.title}</span>
                    <span class="site-navbar__music-playlist-artist">{track.artist}</span>
                  </span>
                </button>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    <!-- IMPORTANT: desktop = hidden, mobile only. Do not remove lg:hidden. -->
    <button
      type="button"
      class="site-navbar__toggle lg:hidden"
      aria-expanded="false"
      aria-controls="site-navbar-panel"
      aria-haspopup="menu"
      data-nav-toggle
    >
      <span class="site-navbar__toggle-bar" aria-hidden="true"></span>
      <span class="site-navbar__toggle-bar" aria-hidden="true"></span>
      <span class="site-navbar__toggle-bar" aria-hidden="true"></span>
      <span class="sr-only">開啟選單</span>
    </button>
  </nav>

  <div
    class="site-navbar__backdrop"
    data-nav-backdrop
    hidden
    aria-hidden="true"
  ></div>

  <div
    id="site-navbar-panel"
    class="site-navbar__menu"
    data-nav-panel
    role="menu"
    hidden
  >
    <ul class="site-navbar__menu-links">
      {
        navLinks.map(({ href, label }) => (
          <li role="none">
            <a
              href={href}
              class:list={[
                "site-navbar__menu-link",
                { "is-active": isActive(href) },
              ]}
              role="menuitem"
              aria-current={isActive(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const MENU_ANIM_MS = 200;
  let navPanelCloseTimer: number | undefined;

  function setNavStage(navbar: HTMLElement, stage: 1 | 2 | 3) {
    navbar.dataset.stage = String(stage);
    navbar.classList.remove("nav-stage-1", "nav-stage-2", "nav-stage-3");
    navbar.classList.add(`nav-stage-${stage}`);
  }

  // Re-queries the live navbar/hero elements every time instead of closing
  // over references captured at bind time — the navbar isn't
  // transition:persist, so real navigations give it fresh DOM nodes, and a
  // stale closure would keep updating an element that's no longer on screen.
  function updateNavbarStage() {
    const navbar = document.querySelector<HTMLElement>("[data-site-navbar]");
    if (!navbar) return;

    const hero = document.getElementById("hero");
    if (!hero) {
      setNavStage(navbar, 3);
      return;
    }

    const scrollY = window.scrollY;
    const heroRect = hero.getBoundingClientRect();
    const navHeight = navbar.offsetHeight;
    const dashboard = document.getElementById("home-dashboard");
    const dashboardTop =
      dashboard?.getBoundingClientRect().top ?? Number.POSITIVE_INFINITY;
    const passedHero =
      heroRect.bottom <= navHeight || dashboardTop <= window.innerHeight * 0.55;

    if (passedHero) {
      setNavStage(navbar, 3);
    } else if (scrollY >= 100) {
      setNavStage(navbar, 2);
    } else {
      setNavStage(navbar, 1);
    }
  }

  function finishCloseNavPanel() {
    const panel = document.querySelector<HTMLElement>("[data-nav-panel]");
    const backdrop = document.querySelector<HTMLElement>("[data-nav-backdrop]");
    if (panel) panel.hidden = true;
    if (backdrop) {
      backdrop.hidden = true;
      backdrop.setAttribute("aria-hidden", "true");
    }
    document.body.classList.remove("nav-open");
  }

  function closeNavPanel() {
    const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
    const panel = document.querySelector<HTMLElement>("[data-nav-panel]");
    const backdrop = document.querySelector<HTMLElement>("[data-nav-backdrop]");
    if (!toggle || !panel || !backdrop) return;
    const srLabel = toggle.querySelector<HTMLElement>(".sr-only");

    window.clearTimeout(navPanelCloseTimer);
    toggle.setAttribute("aria-expanded", "false");
    panel.classList.remove("is-open");
    backdrop.classList.remove("is-open");
    if (srLabel) srLabel.textContent = "開啟選單";

    navPanelCloseTimer = window.setTimeout(finishCloseNavPanel, MENU_ANIM_MS);
  }

  function openNavPanel() {
    const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
    const panel = document.querySelector<HTMLElement>("[data-nav-panel]");
    const backdrop = document.querySelector<HTMLElement>("[data-nav-backdrop]");
    if (!toggle || !panel || !backdrop) return;
    const srLabel = toggle.querySelector<HTMLElement>(".sr-only");

    window.clearTimeout(navPanelCloseTimer);
    panel.hidden = false;
    backdrop.hidden = false;
    backdrop.setAttribute("aria-hidden", "false");
    toggle.setAttribute("aria-expanded", "true");
    document.body.classList.add("nav-open");
    if (srLabel) srLabel.textContent = "關閉選單";

    requestAnimationFrame(() => {
      panel.classList.add("is-open");
      backdrop.classList.add("is-open");
    });
  }

  // `astro:page-load` fires on the first page load AND every subsequent
  // navigation, so `initNavbar` below runs twice on first load — without
  // this guard, that double-run attached two click listeners to the same
  // toggle button. On click, the first listener flipped aria-expanded to
  // "true" and opened the menu; the second listener (same click event, same
  // tick) then read that already-flipped "true" and immediately closed it
  // again — the exact "flashes and collapses" symptom. Elements themselves
  // (WeakSet keys) are fine to guard per-node: real navigations replace the
  // navbar's DOM (it isn't transition:persist), so a genuinely new toggle
  // node still passes the `has()` check and gets bound correctly.
  const boundNavElements = new WeakSet<Element>();
  let navGlobalListenersBound = false;

  function initNavbar() {
    const navbar = document.querySelector<HTMLElement>("[data-site-navbar]");
    const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
    const panel = document.querySelector<HTMLElement>("[data-nav-panel]");
    const backdrop = document.querySelector<HTMLElement>("[data-nav-backdrop]");

    if (!navbar || !toggle || !panel || !backdrop) return;

    updateNavbarStage();

    if (!boundNavElements.has(toggle)) {
      boundNavElements.add(toggle);
      toggle.addEventListener("click", (event) => {
        event.stopPropagation();
        const expanded = toggle.getAttribute("aria-expanded") === "true";
        if (expanded) closeNavPanel();
        else openNavPanel();
      });
    }

    if (!boundNavElements.has(backdrop)) {
      boundNavElements.add(backdrop);
      backdrop.addEventListener("click", closeNavPanel);
    }

    panel.querySelectorAll("a").forEach((link) => {
      if (boundNavElements.has(link)) return;
      boundNavElements.add(link);
      link.addEventListener("click", closeNavPanel);
    });

    // window/document listeners target persistent objects (not recreated
    // per navigation), so they're bound once ever — each handler re-queries
    // the live panel/toggle above instead of closing over this call's nodes.
    if (!navGlobalListenersBound) {
      navGlobalListenersBound = true;

      let ticking = false;
      window.addEventListener(
        "scroll",
        () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            updateNavbarStage();
            const currentPanel = document.querySelector<HTMLElement>("[data-nav-panel]");
            if (currentPanel?.classList.contains("is-open")) closeNavPanel();
            ticking = false;
          });
        },
        { passive: true },
      );

      window.addEventListener("resize", () => {
        updateNavbarStage();
        const currentPanel = document.querySelector<HTMLElement>("[data-nav-panel]");
        if (window.innerWidth >= 1024 && currentPanel?.classList.contains("is-open")) {
          closeNavPanel();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeNavPanel();
      });
    }
  }

  initNavbar();
  document.addEventListener("astro:page-load", initNavbar);

  function applyMusicMiniState(button: HTMLButtonElement, state: any) {
    const playable = Boolean(state?.hasTracks) && !state?.unavailable;
    button.disabled = !playable;
    button.classList.toggle("is-playing", Boolean(state?.isPlaying));
    button.setAttribute("aria-pressed", state?.isPlaying ? "true" : "false");
    button.setAttribute("aria-label", state?.isPlaying ? "暂停音乐" : "播放音乐");
  }

  function applyNowPlaying(root: ParentNode, state: any) {
    const el = root.querySelector<HTMLElement>("[data-now-playing]");
    const textEl = root.querySelector<HTMLElement>("[data-now-playing-text]");
    if (!el || !textEl) return;

    const track = state?.track;
    const show = Boolean(state?.hasTracks) && !state?.unavailable && Boolean(track);

    el.hidden = !show;
    if (!show) return;

    textEl.textContent = `${track.title} - ${track.artist}`;
    el.classList.toggle("is-paused", !state.isPlaying);
  }

  function applyMusicPlaylistState(root: ParentNode, state: any) {
    const playlistToggle = root.querySelector<HTMLButtonElement>("[data-music-playlist-toggle]");
    if (playlistToggle) {
      playlistToggle.disabled = !state?.hasTracks || Boolean(state?.unavailable);
    }
    const items = root.querySelectorAll<HTMLButtonElement>("[data-music-playlist-item]");
    items.forEach((item) => {
      const isCurrent = Number(item.dataset.trackIndex) === state?.index;
      item.classList.toggle("is-current", isCurrent);
      item.setAttribute("aria-selected", isCurrent ? "true" : "false");
    });
  }

  const MUSIC_PLAYLIST_ANIM_MS = 160;

  function prefersReducedMotionNav() {
    return window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  }

  function openMusicPlaylistPanel(panel: HTMLElement, toggleBtn: HTMLButtonElement) {
    window.clearTimeout((panel as any)._closeTimer);
    panel.hidden = false;
    toggleBtn.setAttribute("aria-expanded", "true");
    if (prefersReducedMotionNav()) {
      panel.classList.add("is-open");
    } else {
      requestAnimationFrame(() => panel.classList.add("is-open"));
    }
  }

  function closeMusicPlaylistPanel(panel: HTMLElement, toggleBtn: HTMLButtonElement) {
    window.clearTimeout((panel as any)._closeTimer);
    toggleBtn.setAttribute("aria-expanded", "false");
    panel.classList.remove("is-open");
    if (prefersReducedMotionNav()) {
      panel.hidden = true;
    } else {
      (panel as any)._closeTimer = window.setTimeout(() => {
        panel.hidden = true;
      }, MUSIC_PLAYLIST_ANIM_MS);
    }
  }

  let musicMiniListenersBound = false;

  // See the matching comment in MusicPlayerCard.astro: astro:page-load
  // fires on the first page load AND every navigation, so this function
  // runs twice on first load. Without tracking which button node already
  // has a click listener, that double-run attaches two listeners to the
  // same button — one click then calls sitePlayer.toggle() twice, which
  // caused play() to be interrupted and silently marked "unavailable".
  const boundMusicMiniButtons = new WeakSet<Element>();

  function initMusicMini() {
    const button = document.querySelector<HTMLButtonElement>("[data-music-mini-toggle]");
    if (!button) return;

    const musicRoot = document.querySelector<HTMLElement>("[data-music-mini]");
    const player = (window as any).sitePlayer;
    if (player) {
      applyMusicMiniState(button, player.getState());
      if (musicRoot) applyMusicPlaylistState(musicRoot, player.getState());
      applyNowPlaying(document, player.getState());
    }

    if (!boundMusicMiniButtons.has(button)) {
      boundMusicMiniButtons.add(button);
      button.addEventListener("click", () => {
        (window as any).sitePlayer?.toggle();
      });
    }

    const playlistToggle = document.querySelector<HTMLButtonElement>(
      "[data-music-playlist-toggle]",
    );
    const playlist = document.querySelector<HTMLElement>("[data-music-playlist]");

    if (playlistToggle && playlist && !boundMusicMiniButtons.has(playlistToggle)) {
      boundMusicMiniButtons.add(playlistToggle);
      playlistToggle.addEventListener("click", (event) => {
        event.stopPropagation();
        const isOpen = playlistToggle.getAttribute("aria-expanded") === "true";
        if (isOpen) closeMusicPlaylistPanel(playlist, playlistToggle);
        else openMusicPlaylistPanel(playlist, playlistToggle);
      });
    }

    const playlistItems = document.querySelectorAll<HTMLButtonElement>(
      "[data-music-playlist-item]",
    );
    playlistItems.forEach((item) => {
      if (boundMusicMiniButtons.has(item)) return;
      boundMusicMiniButtons.add(item);
      item.addEventListener("click", () => {
        const index = Number(item.dataset.trackIndex);
        if (Number.isNaN(index)) return;
        (window as any).sitePlayer?.selectTrack(index);
        if (playlist && playlistToggle) closeMusicPlaylistPanel(playlist, playlistToggle);
      });
    });

    // Bind the shared window-level listeners only once ever (separate
    // from the per-button click guard above) — these look up the
    // *current* button live each time they fire, instead of closing over
    // a specific (possibly stale/detached) node, so they don't need to
    // be re-bound per navigation at all.
    if (!musicMiniListenersBound) {
      musicMiniListenersBound = true;

      window.addEventListener("siteplayer:update", (event) => {
        const current = document.querySelector<HTMLButtonElement>("[data-music-mini-toggle]");
        const currentRoot = document.querySelector<HTMLElement>("[data-music-mini]");
        const detail = (event as CustomEvent).detail;
        if (current) applyMusicMiniState(current, detail);
        if (currentRoot) applyMusicPlaylistState(currentRoot, detail);
        applyNowPlaying(document, detail);
      });

      window.addEventListener("siteplayer:ready", () => {
        const current = document.querySelector<HTMLButtonElement>("[data-music-mini-toggle]");
        const currentRoot = document.querySelector<HTMLElement>("[data-music-mini]");
        const p = (window as any).sitePlayer;
        if (!p) return;
        if (current) applyMusicMiniState(current, p.getState());
        if (currentRoot) applyMusicPlaylistState(currentRoot, p.getState());
        applyNowPlaying(document, p.getState());
      });

      // Close the playlist popover on an outside click, on Escape, and
      // proactively before a view-transition swap (so it never appears
      // stuck open after navigating to a new page). These re-query the
      // live DOM each time rather than closing over one specific node.
      document.addEventListener("click", (event) => {
        const currentToggle = document.querySelector<HTMLButtonElement>(
          "[data-music-playlist-toggle]",
        );
        const currentPlaylist = document.querySelector<HTMLElement>("[data-music-playlist]");
        if (!currentToggle || !currentPlaylist || currentPlaylist.hidden) return;
        if (
          event.target instanceof Node &&
          (currentToggle.contains(event.target) || currentPlaylist.contains(event.target))
        ) {
          return;
        }
        closeMusicPlaylistPanel(currentPlaylist, currentToggle);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Escape") return;
        const currentToggle = document.querySelector<HTMLButtonElement>(
          "[data-music-playlist-toggle]",
        );
        const currentPlaylist = document.querySelector<HTMLElement>("[data-music-playlist]");
        if (currentToggle && currentPlaylist && !currentPlaylist.hidden) {
          closeMusicPlaylistPanel(currentPlaylist, currentToggle);
        }
      });

      document.addEventListener("astro:before-swap", () => {
        const currentToggle = document.querySelector<HTMLButtonElement>(
          "[data-music-playlist-toggle]",
        );
        const currentPlaylist = document.querySelector<HTMLElement>("[data-music-playlist]");
        if (currentToggle && currentPlaylist) {
          currentPlaylist.hidden = true;
          currentPlaylist.classList.remove("is-open");
          currentToggle.setAttribute("aria-expanded", "false");
        }
      });
    }
  }

  initMusicMini();
  document.addEventListener("astro:page-load", initMusicMini);
</script>

<style>
  .site-navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      backdrop-filter 0.3s ease;
  }

  .site-navbar__inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 1rem;
    min-height: 4rem;
  }

  .site-navbar__brand-group {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-width: 0;
  }

  .site-navbar__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    text-decoration: none;
    transition: color 0.3s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .site-navbar__now-playing {
    display: none;
    align-items: center;
    gap: 0.3rem;
    margin: 0;
    padding-left: 0.6rem;
    border-left: 1px solid currentColor;
    opacity: 0.55;
    font-size: 0.78rem;
    min-width: 0;
    max-width: 180px;
    overflow: hidden;
    white-space: nowrap;
    transition:
      opacity 0.3s ease,
      color 0.3s ease;
  }

  /* Only show the "now playing" hint once there's enough room next to the
     brand — a cluttered mobile navbar (brand + music icons + hamburger)
     is worse than omitting this secondary detail on small screens. */
  @media (min-width: 640px) {
    .site-navbar__now-playing:not([hidden]) {
      display: inline-flex;
    }
  }

  .site-navbar__now-playing svg {
    width: 0.85rem;
    height: 0.85rem;
    flex-shrink: 0;
  }

  .site-navbar__now-playing-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .site-navbar__now-playing.is-paused {
    opacity: 0.38;
  }

  .site-navbar__logo {
    width: 1.35rem;
    height: 1.35rem;
    color: var(--color-brand);
    flex-shrink: 0;
  }

  .site-navbar__links {
    display: none;
    align-items: center;
    justify-content: flex-end;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 1024px) {
    .site-navbar__links {
      display: flex;
    }
  }

  .site-navbar__link {
    position: relative;
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .site-navbar__link.is-active {
    color: var(--color-brand);
  }

  .site-navbar__link.is-active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.35rem;
    height: 2px;
    border-radius: 999px;
    background-color: currentColor;
  }

  .site-navbar__music {
    position: relative;
    display: flex;
