---
const navLinks = [
  { href: "/", label: "首页" },
  { href: "/blog", label: "文章" },
  { href: "/thoughts", label: "碎碎念" },
  { href: "/gallery", label: "相册" },
  { href: "/guestbook", label: "留言板" },
  { href: "/about", label: "关于我" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

function isActive(href: string) {
  const normalized = href.replace(/\/$/, "") || "/";
  if (normalized === "/") return currentPath === "/";
  return currentPath === normalized || currentPath.startsWith(`${normalized}/`);
}
---

<header
  id="site-navbar"
  class="site-navbar nav-stage-1"
  data-site-navbar
>
  <nav class="site-navbar__inner container-content" aria-label="主要導覽">
    <a href="/" class="site-navbar__brand">
      <svg
        class="site-navbar__logo"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10.5" stroke="currentColor" stroke-width="1.4"></circle>
        <circle cx="9" cy="10.5" r="1" fill="currentColor"></circle>
        <circle cx="15" cy="10.5" r="1" fill="currentColor"></circle>
        <path
          d="M9 14.5c1 1.2 5 1.2 6 0"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"></path>
        <path
          d="M8.5 6.5c.8-.8 2.2-.8 3 0M12.5 6.5c.8-.8 2.2-.8 3 0"
          stroke="currentColor"
          stroke-width="1"
          stroke-linecap="round"></path>
      </svg>
      宛瑜的小窝
    </a>

    <ul class="site-navbar__links">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "site-navbar__link",
                { "is-active": isActive(href) },
              ]}
              aria-current={isActive(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- IMPORTANT: desktop = hidden, mobile only. Do not remove lg:hidden. -->
    <button
      type="button"
      class="site-navbar__toggle lg:hidden"
      aria-expanded="false"
      aria-controls="site-navbar-panel"
      aria-haspopup="menu"
      data-nav-toggle
    >
      <span class="site-navbar__toggle-bar" aria-hidden="true"></span>
      <span class="site-navbar__toggle-bar" aria-hidden="true"></span>
      <span class="site-navbar__toggle-bar" aria-hidden="true"></span>
      <span class="sr-only">開啟選單</span>
    </button>
  </nav>

  <div
    class="site-navbar__backdrop"
    data-nav-backdrop
    hidden
    aria-hidden="true"
  ></div>

  <div
    id="site-navbar-panel"
    class="site-navbar__menu"
    data-nav-panel
    role="menu"
    hidden
  >
    <ul class="site-navbar__menu-links">
      {
        navLinks.map(({ href, label }) => (
          <li role="none">
            <a
              href={href}
              class:list={[
                "site-navbar__menu-link",
                { "is-active": isActive(href) },
              ]}
              role="menuitem"
              aria-current={isActive(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const MENU_ANIM_MS = 200;

  function initNavbar() {
    const navbar = document.querySelector<HTMLElement>("[data-site-navbar]");
    const hero = document.getElementById("hero");
    const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
    const panel = document.querySelector<HTMLElement>("[data-nav-panel]");
    const backdrop = document.querySelector<HTMLElement>("[data-nav-backdrop]");
    const srLabel = toggle?.querySelector<HTMLElement>(".sr-only");

    if (!navbar || !toggle || !panel || !backdrop) return;

    const hasHero = Boolean(hero);
    let closeTimer: number | undefined;

    function setStage(stage: 1 | 2 | 3) {
      navbar!.dataset.stage = String(stage);
      navbar!.classList.remove("nav-stage-1", "nav-stage-2", "nav-stage-3");
      navbar!.classList.add(`nav-stage-${stage}`);
    }

    function updateNavbarStage() {
      if (!hasHero) {
        setStage(3);
        return;
      }

      const scrollY = window.scrollY;
      const heroRect = hero!.getBoundingClientRect();
      const navHeight = navbar!.offsetHeight;
      const dashboard = document.getElementById("home-dashboard");
      const dashboardTop =
        dashboard?.getBoundingClientRect().top ?? Number.POSITIVE_INFINITY;
      const passedHero =
        heroRect.bottom <= navHeight ||
        dashboardTop <= window.innerHeight * 0.55;

      if (passedHero) {
        setStage(3);
      } else if (scrollY >= 100) {
        setStage(2);
      } else {
        setStage(1);
      }
    }

    function finishClose() {
      panel.hidden = true;
      backdrop.hidden = true;
      backdrop.setAttribute("aria-hidden", "true");
      document.body.classList.remove("nav-open");
    }

    function closePanel() {
      window.clearTimeout(closeTimer);
      toggle.setAttribute("aria-expanded", "false");
      panel.classList.remove("is-open");
      backdrop.classList.remove("is-open");
      if (srLabel) srLabel.textContent = "開啟選單";

      closeTimer = window.setTimeout(finishClose, MENU_ANIM_MS);
    }

    function openPanel() {
      window.clearTimeout(closeTimer);
      panel.hidden = false;
      backdrop.hidden = false;
      backdrop.setAttribute("aria-hidden", "false");
      toggle.setAttribute("aria-expanded", "true");
      document.body.classList.add("nav-open");
      if (srLabel) srLabel.textContent = "關閉選單";

      requestAnimationFrame(() => {
        panel.classList.add("is-open");
        backdrop.classList.add("is-open");
      });
    }

    updateNavbarStage();

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        updateNavbarStage();
        if (panel.classList.contains("is-open")) closePanel();
        ticking = false;
      });
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", () => {
      updateNavbarStage();
      if (window.innerWidth >= 1024 && panel.classList.contains("is-open")) {
        closePanel();
      }
    });

    toggle.addEventListener("click", (event) => {
      event.stopPropagation();
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      if (expanded) closePanel();
      else openPanel();
    });

    backdrop.addEventListener("click", closePanel);

    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closePanel);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closePanel();
    });
  }

  initNavbar();
  document.addEventListener("astro:page-load", initNavbar);
</script>

<style>
  .site-navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      backdrop-filter 0.3s ease;
  }

  .site-navbar__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    min-height: 4rem;
  }

  .site-navbar__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    text-decoration: none;
    transition: color 0.3s ease;
    white-space: nowrap;
  }

  .site-navbar__logo {
    width: 1.35rem;
    height: 1.35rem;
    color: var(--color-brand);
    flex-shrink: 0;
  }

  .site-navbar__links {
    display: none;
    align-items: center;
    justify-content: flex-end;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 1024px) {
    .site-navbar__links {
      display: flex;
    }
  }

  .site-navbar__link {
    position: relative;
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .site-navbar__link.is-active {
    color: var(--color-brand);
  }

  .site-navbar__link.is-active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.35rem;
    height: 2px;
    border-radius: 999px;
    background-color: currentColor;
  }

  .site-navbar__toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.3rem;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0.4rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
    justify-self: end;
    transition: background-color 0.3s ease;
  }

  /* Cascade fix: base toggle sets display:inline-flex above; hide rules must come after. */
  @media (min-width: 1024px) {
    .site-navbar__toggle,
    .site-navbar__menu,
    .site-navbar__backdrop {
      display: none;
    }
  }

  .site-navbar__toggle-bar {
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 999px;
    transition:
      transform 200ms ease,
      opacity 200ms ease,
      background-color 0.3s ease;
  }

  .site-navbar__toggle[aria-expanded="true"] .site-navbar__toggle-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .site-navbar__toggle[aria-expanded="true"] .site-navbar__toggle-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .site-navbar__toggle[aria-expanded="true"] .site-navbar__toggle-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .site-navbar__backdrop {
    position: fixed;
    inset: 0;
    z-index: 55;
    background: rgb(60 50 40 / 8%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
  }

  .site-navbar__backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .site-navbar__menu {
    position: fixed;
    top: calc(4rem + 8px);
    right: 12px;
    z-index: 60;
    width: max-content;
    min-width: 200px;
    max-width: 240px;
    padding: 12px 8px;
    border-radius: 20px;
    background-color: var(--color-surface);
    box-shadow: 0 8px 28px rgb(91 81 72 / 10%), 0 2px 8px rgb(91 81 72 / 6%);
    opacity: 0;
    transform: scale(0.96);
    transform-origin: top right;
    pointer-events: none;
    transition:
      opacity 200ms ease,
      transform 200ms ease;
  }

  .site-navbar__menu.is-open {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-navbar__menu,
    .site-navbar__backdrop,
    .site-navbar__toggle-bar {
      transition-duration: 0.01ms;
    }

    .site-navbar__menu {
      transform: none;
    }

    .site-navbar__menu.is-open {
      transform: none;
    }
  }

  .site-navbar__menu-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .site-navbar__menu-link {
    display: block;
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 0.95rem;
    line-height: 1.4;
    text-decoration: none;
    color: var(--color-text-primary);
    transition:
      background-color 200ms ease,
      color 200ms ease;
  }

  .site-navbar__menu-link:hover {
    background-color: rgb(243 238 230 / 70%);
  }

  .site-navbar__menu-link.is-active {
    color: var(--color-brand);
    background-color: rgb(231 185 138 / 18%);
  }

  /* Stage 1 — transparent over hero */
  .site-navbar.nav-stage-1 {
    background-color: transparent;
    border-bottom: 1px solid transparent;
    box-shadow: none;
    backdrop-filter: none;
  }

  .site-navbar.nav-stage-1 .site-navbar__brand,
  .site-navbar.nav-stage-1 .site-navbar__link {
    color: #fff9f2;
    text-shadow:
      0 1px 8px rgb(60 50 40 / 42%),
      0 2px 18px rgb(60 50 40 / 24%);
  }

  .site-navbar.nav-stage-1 .site-navbar__logo {
    color: #fff9f2;
  }

  .site-navbar.nav-stage-1 .site-navbar__link.is-active {
    color: #fff9f2;
    text-shadow:
      0 1px 10px rgb(60 50 40 / 48%),
      0 2px 20px rgb(60 50 40 / 28%);
  }

  .site-navbar.nav-stage-1 .site-navbar__link.is-active::after {
    background-color: var(--color-brand);
    box-shadow: 0 1px 8px rgb(60 50 40 / 30%);
  }

  .site-navbar.nav-stage-1 .site-navbar__toggle-bar {
    background-color: #fff9f2;
    box-shadow: 0 1px 8px rgb(91 81 72 / 22%);
  }

  /* Stage 2 — frosted glass */
  .site-navbar.nav-stage-2 {
    background-color: rgb(255 253 248 / 72%);
    border-bottom: 1px solid rgb(236 229 218 / 55%);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 4px 20px rgb(91 81 72 / 6%);
  }

  .site-navbar.nav-stage-2 .site-navbar__brand,
  .site-navbar.nav-stage-2 .site-navbar__link,
  .site-navbar.nav-stage-2 .site-navbar__toggle-bar {
    color: var(--color-text-primary);
    text-shadow: none;
  }

  .site-navbar.nav-stage-2 .site-navbar__logo {
    color: var(--color-brand);
  }

  .site-navbar.nav-stage-2 .site-navbar__toggle-bar {
    background-color: var(--color-text-primary);
  }

  .site-navbar.nav-stage-2 .site-navbar__link.is-active {
    color: var(--color-brand);
  }

  /* Stage 3 — solid cream */
  .site-navbar.nav-stage-3 {
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-divider);
    backdrop-filter: none;
    box-shadow: none;
  }

  .site-navbar.nav-stage-3 .site-navbar__brand,
  .site-navbar.nav-stage-3 .site-navbar__link,
  .site-navbar.nav-stage-3 .site-navbar__toggle-bar {
    color: var(--color-text-primary);
    text-shadow: none;
  }

  .site-navbar.nav-stage-3 .site-navbar__logo {
    color: var(--color-brand);
  }

  .site-navbar.nav-stage-3 .site-navbar__toggle-bar {
    background-color: var(--color-text-primary);
  }

  .site-navbar.nav-stage-3 .site-navbar__link.is-active {
    color: var(--color-brand);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
