---
// Functional chat widget backed by a Cloudflare Worker. This is
// intentionally kept as a self-contained vanilla-JS Astro component (no
// framework island) — the state involved (a message list + a couple of
// localStorage values) is simple enough that plain DOM manipulation is
// sufficient, consistent with the rest of this site's client scripts.
---

<section class="ai-chat" data-ai-chat data-reveal="content">
  <div class="ai-chat__header">
    <span class="ai-chat__header-emoji" aria-hidden="true">💬</span>
    <div class="ai-chat__header-text">
      <p class="ai-chat__title">跟宛瑜聊聊天</p>
      <p class="ai-chat__subtitle">随便说点什么都可以，我都在听～</p>
    </div>
  </div>

  <div class="ai-chat__messages" data-ai-chat-messages role="log" aria-live="polite">
    <div class="ai-chat__bubble ai-chat__bubble--bot">嗨～我是宛瑜，找我聊天呀 🌼</div>
  </div>

  <form class="ai-chat__form" data-ai-chat-form>
    <textarea
      class="ai-chat__input"
      data-ai-chat-input
      rows="1"
      maxlength="500"
      placeholder="想说点什么…"
      aria-label="输入消息"
    ></textarea>
    <button type="submit" class="ai-chat__send" data-ai-chat-send aria-label="发送">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path
          d="M4 12 20 4l-6 16-3-6-7-2Z"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linejoin="round"
          stroke-linecap="round"></path>
      </svg>
    </button>
  </form>
</section>

<script>
  const CHAT_API = "https://wanyu-ai-chat.papersheep123.workers.dev";
  const VISITOR_ID_KEY = "wanyu_visitor_id";
  const ADMIN_SECRET_KEY = "wanyu_admin_secret";

  function getVisitorId() {
    try {
      let id = localStorage.getItem(VISITOR_ID_KEY);
      if (!id) {
        id = crypto.randomUUID();
        localStorage.setItem(VISITOR_ID_KEY, id);
      }
      return id;
    } catch {
      // localStorage unavailable (e.g. private browsing) — fall back to a
      // session-only id so the chat still works, just without persistence.
      return "session-only";
    }
  }

  function syncAdminSecretFromUrl() {
    try {
      const params = new URLSearchParams(window.location.search);
      const admin = params.get("admin");
      if (admin) localStorage.setItem(ADMIN_SECRET_KEY, admin);
    } catch {
      // Ignore — worst case the admin secret just doesn't get saved.
    }
  }

  function getAdminSecret() {
    try {
      return localStorage.getItem(ADMIN_SECRET_KEY) || "";
    } catch {
      return "";
    }
  }

  function appendBubble(container: HTMLElement, text: string, kind: "user" | "bot" | "error") {
    const bubble = document.createElement("div");
    bubble.className = `ai-chat__bubble ai-chat__bubble--${kind}`;
    bubble.textContent = text;
    container.appendChild(bubble);
    container.scrollTop = container.scrollHeight;
    return bubble;
  }

  // Rendered as a real bubble in the message flow (not a separate plain-text
  // element) so it scrolls and aligns exactly like a normal reply, and reads
  // as "宛瑜 is drafting a message" rather than a generic loading state.
  function appendTypingBubble(container: HTMLElement) {
    const bubble = document.createElement("div");
    bubble.className = "ai-chat__bubble ai-chat__bubble--bot ai-chat__bubble--typing";
    bubble.textContent = "宛瑜正在打字…";
    container.appendChild(bubble);
    container.scrollTop = container.scrollHeight;
    return bubble;
  }

  function autoResize(textarea: HTMLTextAreaElement) {
    textarea.style.height = "auto";
    textarea.style.height = `${Math.min(textarea.scrollHeight, 96)}px`;
  }

  async function sendChatMessage(
    messagesEl: HTMLElement,
    input: HTMLTextAreaElement,
    sendBtn: HTMLButtonElement,
  ) {
    const text = input.value.trim();
    if (!text) return;

    input.value = "";
    autoResize(input);
    appendBubble(messagesEl, text, "user");

    input.disabled = true;
    sendBtn.disabled = true;
    const typingBubble = appendTypingBubble(messagesEl);

    try {
      const res = await fetch(CHAT_API, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          message: text,
          visitorId: getVisitorId(),
          adminSecret: getAdminSecret(),
        }),
      });
      if (!res.ok) throw new Error(`ai chat api ${res.status}`);
      const data = await res.json();
      if (data?.error) throw new Error(String(data.error));
      typingBubble.remove();
      appendBubble(messagesEl, typeof data?.reply === "string" ? data.reply : "……", "bot");
    } catch {
      // Fail gracefully — never surface a raw error or broken UI, this is
      // a low-stakes/best-effort feature.
      typingBubble.remove();
      appendBubble(messagesEl, "宛瑜好像不在，晚点再试试～", "error");
    } finally {
      input.disabled = false;
      sendBtn.disabled = false;
      input.focus();
    }
  }

  // `astro:page-load` fires on the first page load *and* every subsequent
  // navigation, so this init function runs twice on a page's first load.
  // Tracking already-bound elements avoids attaching duplicate listeners
  // to the same form/textarea — the same guard used for the music player
  // controls after that exact bug was found there.
  const boundAiChatControls = new WeakSet<Element>();

  function initAiChatWidget() {
    const widget = document.querySelector<HTMLElement>("[data-ai-chat]");
    if (!widget) return;

    syncAdminSecretFromUrl();

    const messagesEl = widget.querySelector<HTMLElement>("[data-ai-chat-messages]");
    const form = widget.querySelector<HTMLFormElement>("[data-ai-chat-form]");
    const input = widget.querySelector<HTMLTextAreaElement>("[data-ai-chat-input]");
    const sendBtn = widget.querySelector<HTMLButtonElement>("[data-ai-chat-send]");

    if (!messagesEl || !form || !input || !sendBtn) return;

    if (!boundAiChatControls.has(form)) {
      boundAiChatControls.add(form);
      form.addEventListener("submit", (event) => {
        event.preventDefault();
        sendChatMessage(messagesEl, input, sendBtn);
      });
    }

    if (!boundAiChatControls.has(input)) {
      boundAiChatControls.add(input);
      input.addEventListener("keydown", (event) => {
        if (event.key === "Enter" && !event.shiftKey) {
          event.preventDefault();
          form.requestSubmit();
        }
      });
      input.addEventListener("input", () => autoResize(input));
    }
  }

  initAiChatWidget();
  document.addEventListener("astro:page-load", initAiChatWidget);
</script>

<style>
  .ai-chat {
    display: flex;
    flex-direction: column;
    margin-bottom: 4.5rem;
    padding: 1.5rem;
    border-radius: var(--radius-card-lg);
    background-color: var(--color-surface);
    box-shadow: var(--shadow-card);
  }

  .ai-chat__header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1.1rem;
  }

  .ai-chat__header-emoji {
    font-size: 1.5rem;
    line-height: 1;
  }

  .ai-chat__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-text-primary);
  }

  .ai-chat__subtitle {
    margin: 0.15rem 0 0;
    font-size: 0.82rem;
    color: var(--color-text-secondary);
  }

  .ai-chat__messages {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-height: 320px;
    overflow-y: auto;
    padding: 0.25rem 0.15rem 0.5rem;
    margin-bottom: 0.4rem;
  }

  /*
   * Except for the initial static greeting in the markup above, every
   * .ai-chat__bubble element (user messages, bot replies, the typing
   * indicator, error bubbles) is created client-side via
   * document.createElement in the <script> below. Astro only injects its
   * scoping attribute (data-astro-cid-*) into elements present in this
   * component's own template — dynamically created nodes never get it, so
   * an unscoped selector here would silently fail to match them. These
   * rules are wrapped in :global() so they match by class name alone,
   * regardless of scoping — the same fix already applied in
   * GuestbookPreview.astro for its client-created avatar elements.
   */
  :global(.ai-chat__bubble) {
    max-width: 80%;
    padding: 0.6rem 0.9rem;
    border-radius: 16px;
    font-size: 0.9rem;
    line-height: 1.6;
    overflow-wrap: anywhere;
    white-space: pre-wrap;
    opacity: 0;
    transform: translateY(6px);
    animation: ai-chat-bubble-in 0.25s ease forwards;
  }

  @keyframes ai-chat-bubble-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(.ai-chat__bubble--bot) {
    align-self: flex-start;
    background-color: var(--color-surface-alt);
    color: var(--color-text-primary);
    border-bottom-left-radius: 4px;
  }

  :global(.ai-chat__bubble--user) {
    align-self: flex-end;
    background-color: var(--color-brand);
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  :global(.ai-chat__bubble--error) {
    align-self: flex-start;
    background-color: rgb(235 201 196 / 35%);
    color: var(--color-text-primary);
    border-bottom-left-radius: 4px;
  }

  :global(.ai-chat__bubble--typing) {
    color: var(--color-text-secondary);
  }

  .ai-chat__form {
    display: flex;
    align-items: flex-end;
    gap: 0.6rem;
  }

  .ai-chat__input {
    flex: 1;
    min-width: 0;
    resize: none;
    max-height: 96px;
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--color-divider);
    border-radius: 16px;
    background-color: var(--color-background);
    color: var(--color-text-primary);
    font-family: inherit;
    font-size: 0.9rem;
    line-height: 1.5;
    transition: border-color 0.2s ease;
  }

  .ai-chat__input:focus {
    outline: none;
    border-color: var(--color-brand);
  }

  .ai-chat__send {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 0;
    border-radius: 999px;
    background-color: var(--color-brand);
    color: #fff;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .ai-chat__send svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .ai-chat__send:hover:not(:disabled) {
    opacity: 0.88;
  }

  .ai-chat__send:disabled {
    opacity: 0.45;
    cursor: default;
  }

  @media (max-width: 480px) {
    .ai-chat {
      padding: 1.15rem;
    }

    :global(.ai-chat__bubble) {
      max-width: 88%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.ai-chat__bubble) {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .ai-chat__input,
    .ai-chat__send {
      transition: none;
    }
  }
</style>
