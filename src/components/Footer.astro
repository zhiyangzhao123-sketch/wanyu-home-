---
---

<footer class="site-footer border-t border-divider bg-surface-alt">
  <div class="site-footer__doodle site-footer__doodle--left" aria-hidden="true">
    <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M18 58c0-8 4-14 10-18 3-2 6-2 8 0 2-4 5-8 10-10"
        stroke="#A9C8A2"
        stroke-width="1.6"
        stroke-linecap="round"></path>
      <ellipse cx="18" cy="58" rx="8" ry="4" fill="#EFF5E8"></ellipse>
      <rect x="42" y="36" width="18" height="12" rx="2" fill="#EBC9C4" opacity="0.55"></rect>
      <path d="M44 36V32h14v4" stroke="#5B5148" stroke-width="1.2" opacity="0.45"></path>
      <line x1="47" y1="40" x2="55" y2="40" stroke="#5B5148" stroke-width="1" opacity="0.35"></line>
    </svg>
  </div>

  <div class="site-footer__doodle site-footer__doodle--right" aria-hidden="true">
    <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M20 42c2-6 8-10 14-10 4 0 8 2 10 6 2-1 5-1 7 1 3 2 5 6 5 10"
        stroke="#E7B98A"
        stroke-width="1.5"
        stroke-linecap="round"></path>
      <circle cx="24" cy="40" r="1.2" fill="#5B5148"></circle>
      <circle cx="30" cy="38" r="1.2" fill="#5B5148"></circle>
      <path
        d="M48 48h10v12c0 2-1.5 3.5-3.5 3.5h-3c-2 0-3.5-1.5-3.5-3.5V48Z"
        stroke="#EBC9C4"
        stroke-width="1.3"></path>
      <path d="M46 48h14v4H46v-4Z" fill="#E7B98A" opacity="0.65"></path>
    </svg>
  </div>

  <div class="container-content site-footer__content">
    <p class="site-footer__text">谢谢你今天来看我。希望今天也有一点点开心 ☁️</p>
    <p class="site-footer__copy">© 宛瑜的小窝</p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    padding-block: 5rem 4.5rem;
  }

  .site-footer__content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .site-footer__text {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 15px;
    line-height: 1.8;
  }

  .site-footer__copy {
    margin: 0.5rem 0 0;
    color: rgb(138 129 120 / 70%);
    font-size: 0.875rem;
  }

  .site-footer__doodle {
    position: absolute;
    bottom: 0.75rem;
    width: 72px;
    height: 72px;
    opacity: 0.75;
    pointer-events: none;
  }

  .site-footer__doodle svg {
    width: 100%;
    height: 100%;
  }

  .site-footer__doodle--left {
    left: 1rem;
  }

  .site-footer__doodle--right {
    right: 1rem;
  }

  @media (max-width: 640px) {
    .site-footer__doodle {
      width: 56px;
      height: 56px;
      opacity: 0.55;
    }
  }
</style>
