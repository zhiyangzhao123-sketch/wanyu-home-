---

import SectionHeader from "./SectionHeader.astro";

import g01 from "../assets/gallery/g-01.jpg";

import g02 from "../assets/gallery/g-02.jpg";

import g03 from "../assets/gallery/g-03.jpg";

import g04 from "../assets/gallery/g-04.jpg";

import g05 from "../assets/gallery/g-05.jpg";

import g06 from "../assets/gallery/g-06.jpg";



const photos = [g01, g02, g03, g04, g05, g06];

---



<section class="side-card gallery-preview" data-reveal="content">

  <SectionHeader

    emoji="📷"

    title="近期相册"

    linkHref="/gallery"

    linkLabel="查看更多 →"

  />



  <div class="gallery-preview__grid">

    {

      photos.map((photo) => (

        <a href="/gallery" class="gallery-preview__item" aria-label="查看相册">

          <img

            src={photo.src}

            alt=""

            width={photo.width}

            height={photo.height}

            loading="lazy"

            decoding="async"

          />

        </a>

      ))

    }

  </div>

</section>



<style>

  .gallery-preview {

    background-color: var(--color-surface);

    border-radius: 20px;

    padding: 1.15rem 1.1rem 1.2rem;

    box-shadow: var(--shadow-card);

  }



  .gallery-preview__grid {

    display: grid;

    grid-template-columns: repeat(3, 1fr);

    gap: 0.45rem;

  }



  .gallery-preview__item {

    aspect-ratio: 1;

    border-radius: 10px;

    overflow: hidden;

    transition:

      transform 0.3s ease,

      box-shadow 0.3s ease;

    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 35%);

  }



  .gallery-preview__item img {

    width: 100%;

    height: 100%;

    object-fit: cover;

    display: block;

  }



  .gallery-preview__item:hover {

    transform: scale(1.04);

    box-shadow: 0 4px 12px rgb(91 81 72 / 10%);

  }

</style>


