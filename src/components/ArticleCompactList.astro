---
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import SectionHeader from "./SectionHeader.astro";
import CategoryPill from "./CategoryPill.astro";
import { formatDate, getReadingMinutes } from "../utils/content";
import cover01 from "../assets/covers/cover-01.jpg";
import cover02 from "../assets/covers/cover-02.jpg";
import cover03 from "../assets/covers/cover-03.jpg";

const coverMap: Record<string, ImageMetadata> = {
  "cover-01": cover01,
  "cover-02": cover02,
  "cover-03": cover03,
};

const articles = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section id="latest-articles" class="articles-compact" data-reveal="content">
  <SectionHeader
    emoji="📖"
    title="最新文章"
    linkHref="/blog"
    linkLabel="查看全部 →"
  />

  <div class="articles-compact__list">
    {
      articles.map((article) => {
        const coverKey = article.data.cover ?? "";
        const cover = coverMap[coverKey];
        const readingMinutes = getReadingMinutes(article.body ?? "");

        return (
          <article class="articles-compact__item" data-reveal="content" data-reveal-delay="80">
            {cover && (
              <a
                href={`/blog/${article.id}/`}
                class="articles-compact__thumb"
                aria-label={`阅读：${article.data.title}`}
              >
                <img
                  src={cover.src}
                  alt=""
                  width={160}
                  height={110}
                  loading="lazy"
                  decoding="async"
                />
              </a>
            )}
            <div class="articles-compact__body">
              <CategoryPill category={article.data.category} />
              <h3 class="articles-compact__title">
                <a href={`/blog/${article.id}/`}>{article.data.title}</a>
              </h3>
              <p class="articles-compact__desc">{article.data.description}</p>
              <div class="articles-compact__meta">
                <time datetime={article.data.pubDate.toISOString()}>
                  {formatDate(article.data.pubDate)}
                </time>
                <span aria-hidden="true">·</span>
                <span>约 {readingMinutes} 分钟</span>
                <a href={`/blog/${article.id}/`} class="articles-compact__read">
                  继续阅读 →
                </a>
              </div>
            </div>
          </article>
        );
      })
    }
  </div>
</section>

<style>
  .articles-compact__list {
    display: flex;
    flex-direction: column;
  }

  .articles-compact__item + .articles-compact__item {
    margin-top: 0.85rem;
    padding-top: 0.85rem;
    border-top: 1px solid rgb(236 229 218 / 85%);
  }

  .articles-compact__item {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1rem;
    align-items: start;
    padding: 0.35rem 0;
  }

  .articles-compact__thumb {
    display: block;
    width: 160px;
    height: 110px;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: var(--shadow-card);
  }

  .articles-compact__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .articles-compact__item:hover .articles-compact__thumb img {
    transform: scale(1.03);
  }

  .articles-compact__title {
    margin: 0.55rem 0 0;
    font-family: var(--font-heading);
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    line-height: 1.45;
  }

  .articles-compact__title a {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .articles-compact__item:hover .articles-compact__title a {
    color: var(--color-brand);
  }

  .articles-compact__desc {
    margin: 0.4rem 0 0;
    color: var(--color-text-secondary);
    font-size: 0.86rem;
    line-height: 1.65;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    overflow: hidden;
  }

  .articles-compact__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.5rem;
    margin-top: 0.55rem;
    color: var(--color-text-secondary);
    font-size: 0.78rem;
  }

  .articles-compact__read {
    margin-left: auto;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .articles-compact__read:hover {
    color: var(--color-brand);
  }

  @media (max-width: 640px) {
    .articles-compact__item {
      grid-template-columns: 1fr;
    }

    .articles-compact__thumb {
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 10;
    }

    .articles-compact__read {
      margin-left: 0;
    }
  }
</style>
