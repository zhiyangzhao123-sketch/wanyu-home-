---
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import SiteAudioPlayer from "../components/SiteAudioPlayer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "宛瑜的小窝",
  description = "记录一点生活，分享一点温柔。",
} = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <!--
      Defense-in-depth only: GitHub Pages' own "Enforce HTTPS" setting for
      the linwanyu.top custom domain is the real fix (a platform-level
      redirect issued before any HTML/JS loads) and should be verified/kept
      on in the repo's Settings → Pages. This inline script is a client-side
      fallback for the rare case that setting is off or a stale www./http
      link is bookmarked — it only ever targets the known production
      hostnames, never localhost/preview URLs, so local `astro dev` is
      unaffected.
    -->
    <script is:inline>
      (function () {
        var canonicalHost = "linwanyu.top";
        var host = window.location.hostname;
        var isHttpOnApex = host === canonicalHost && window.location.protocol === "http:";
        var isWww = host === "www." + canonicalHost;
        if (isHttpOnApex || isWww) {
          window.location.replace(
            "https://" +
              canonicalHost +
              window.location.pathname +
              window.location.search +
              window.location.hash,
          );
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col bg-background text-text-primary">
    <SiteAudioPlayer />
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <ScrollReveal />
  </body>
</html>
